# --- Database ---
# Runtime : connexion poolée (pgBouncer) en prod. En local, pooler = direct.
DATABASE_URL="postgresql://plal:plal@localhost:5432/plal?schema=public"
# Migrations : connexion directe (requis par Prisma `directUrl`). En local, identique à DATABASE_URL.
DIRECT_URL="postgresql://plal:plal@localhost:5432/plal?schema=public"

# --- Production (Supabase) — exemple, à mettre dans les variables Vercel ---
# DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Auth ---
JWT_SECRET="change-me-in-production-please-use-a-long-random-string"
JWT_EXPIRES_IN="7d"

# --- Server ---
PORT=4000
# Origine autorisée pour le CORS (frontend)
WEB_ORIGIN="http://localhost:3000"

# --- Google OAuth (optionnel, non utilisé au MVP) ---
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
