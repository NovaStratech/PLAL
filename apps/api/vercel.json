{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install -g pnpm@9.15.9 && pnpm install --no-frozen-lockfile --prod=false",
  "buildCommand": "pnpm exec prisma generate",
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "functions": {
    "api/index.ts": {
      "includeFiles": "../../node_modules/.pnpm/@prisma+client*/node_modules/.prisma/client/**",
      "maxDuration": 30
    }
  }
}
